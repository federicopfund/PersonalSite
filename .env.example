# Copia este archivo a .env y completa tus credenciales SMTP.
#   cp .env.example .env
# Docker Compose lee .env automaticamente al hacer `docker compose up`.
# El archivo .env esta en .gitignore: NUNCA se commitea.

# Cuenta Gmail desde la que sale el correo.
SMTP_USER=federicopfund@gmail.com

# App Password de 16 caracteres (NO tu contrasena normal de Gmail).
# Generala en: https://myaccount.google.com/apppasswords
# Pegala sin espacios.
SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# Opcional: remitente visible (por defecto = SMTP_USER).
# SMTP_FROM=federicopfund@gmail.com
